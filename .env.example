# ==============================
# ENVIRONMENT VARIABLES
# Salin file ini menjadi .env
# Jangan commit .env ke GitHub!
# ==============================

# Server
PORT=5000
NODE_ENV=development

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=portfolio_db

# JWT Secret (ganti dengan string acak yang kuat)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email (untuk nodemailer — gunakan Gmail App Password)
EMAIL_USER=khairunnisa@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_TO=khairunnisa@gmail.com

# CORS (domain frontend Anda)
FRONTEND_URL=http://localhost:3000

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
